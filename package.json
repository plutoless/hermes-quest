{
  "name": "hermes-companion",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc -b && vite build",
    "lint": "tsc -b --pretty false",
    "test": "bun test",
    "check:tauri-config": "node scripts/check-tauri-config.mjs",
