{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default window permissions for Hermes Companion.",
  "windows": ["main", "pet", "appearance", "companions", "settings", "companion-*"],
  "permissions": [
    "core:default",
    "core:window:allow-start-dragging",
    "core:window:allow-show",
    "core:window:allow-unminimize",
    "core:window:allow-set-focus"
  ]
}
